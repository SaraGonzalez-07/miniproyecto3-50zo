<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Pos?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example._0zo.controller._0zoController"
            stylesheets="@style.css"
            fx:id="rootPane">


    <!-- BARRA SUPERIOR -->
    <top>

        <HBox spacing="20"
              alignment="CENTER"
              styleClass="top-bar">


            <Button text="Salir"
                    fx:id="btnSalir"
                    styleClass="casino-button danger"/>


            <Button text="Reiniciar"
                    fx:id="btnReiniciar"
                    styleClass="casino-button"/>


            <Label text="HISTORIAL DE JUGADAS"
                   styleClass="title"/>


        </HBox>

    </top>



    <!-- JUGADORES LATERALES -->

    <left>

        <VBox spacing="20"
              alignment="CENTER"
              styleClass="player-zone">


            <Label text="Jugador Izquierda"
                   fx:id="nombreJugadorIzquierda"
                   styleClass="player-name"/>


            <Circle radius="35"
                    styleClass="avatar"/>


            <Label text="Cartas: 5"
                   fx:id="cartasIzquierda"
                   styleClass="player-info"/>


            <Label text="Puntos: 0"
                   fx:id="puntosIzquierda"
                   styleClass="player-info"/>


        </VBox>


    </left>




    <right>


        <VBox spacing="20"
              alignment="CENTER"
              styleClass="player-zone">


            <Label text="Jugador Derecha"
                   fx:id="nombreJugadorDerecha"
                   styleClass="player-name"/>


            <Circle radius="35"
                    styleClass="avatar"/>


            <Label text="Cartas: 5"
                   fx:id="cartasDerecha"
                   styleClass="player-info"/>


            <Label text="Puntos: 0"
                   fx:id="puntosDerecha"
                   styleClass="player-info"/>


        </VBox>


    </right>






    <!-- ZONA CENTRAL DEL JUEGO -->

    <center>


        <GridPane hgap="30"
                  vgap="30"
                  alignment="CENTER"
                  styleClass="table">


            <!-- CONTADOR -->

            <VBox GridPane.rowIndex="0"
                  GridPane.columnIndex="1"
                  alignment="CENTER">


                <Label text="SUMA ACTUAL"
                       styleClass="counter-title"/>


                <Label text="0"
                       fx:id="lblSumaMesa"
                       styleClass="counter"/>


            </VBox>





            <!-- MAZO -->

            <VBox GridPane.rowIndex="1"
                  GridPane.columnIndex="0"
                  alignment="CENTER">


                <Label text="Mazo"
                       styleClass="card-label"/>


                <StackPane fx:id="mazoRobo"
                           styleClass="card back-card">


                    <Label text="50"
                           styleClass="card-back-text"/>


                </StackPane>


            </VBox>





            <!-- DESCARTE -->


            <VBox GridPane.rowIndex="1"
                  GridPane.columnIndex="2"
                  alignment="CENTER">


                <Label text="Pila Actual"
                       styleClass="card-label"/>


                <StackPane fx:id="pilaDescarte"
                           styleClass="card">


                    <Label text="?"
                           fx:id="cartaActualMesa"/>


                </StackPane>


            </VBox>



        </GridPane>



    </center>








    <!-- JUGADOR PRINCIPAL -->


    <bottom>


        <VBox spacing="15"
              alignment="CENTER"
              styleClass="main-player">


            <Label text="Tu Mano"
                   fx:id="nombreJugadorPrincipal"
                   styleClass="player-name"/>




            <HBox fx:id="manoJugador"
                  spacing="15"
                  alignment="CENTER"
                  styleClass="hand">


                <!-- Cartas dinámicas -->


                <StackPane fx:id="carta1"
                           styleClass="card">

                    <Label text="7"/>

                </StackPane>



                <StackPane fx:id="carta2"
                           styleClass="card">

                    <Label text="10"/>

                </StackPane>



                <StackPane fx:id="carta3"
                           styleClass="card">

                    <Label text="5"/>

                </StackPane>



            </HBox>


        </VBox>


    </bottom>




</BorderPane>