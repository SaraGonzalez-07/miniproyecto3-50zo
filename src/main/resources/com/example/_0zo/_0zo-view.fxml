<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.example._0zo.controller._0zoController"
            styleClass="main-container"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <top>
        <VBox alignment="CENTER" styleClass="header-panel">
            <children>
                <Label styleClass="game-title" text="_0zo" />
                <HBox alignment="CENTER" spacing="40" styleClass="score-container">
                    <children>
                        <VBox alignment="CENTER">
                            <Label styleClass="score-label" text="PUNTUACIÓN" />
                            <Label fx:id="scoreValue" styleClass="score-value" text="0000" />
                        </VBox>
                        <VBox alignment="CENTER">
                            <Label styleClass="score-label" text="ESTADO" />
                            <Label fx:id="statusValue" styleClass="status-value" text="Tu Turno" />
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" styleClass="game-board">
            <children>
                <Label fx:id="boardPlaceholder" styleClass="board-placeholder" text="[ ÁREA DEL JUEGO _0zo ]" />
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="action-panel">
            <children>
                <Button mnemonicParsing="false" onAction="#handleFoldAction" text="Retirarse">
                    <styleClass>
                        <String fx:value="btn-action" />
                        <String fx:value="btn-secondary" />
                    </styleClass>
                </Button>
                <Button mnemonicParsing="false" onAction="#handleBetAction" text="¡APRESTAR!">
                    <styleClass>
                        <String fx:value="btn-action" />
                        <String fx:value="btn-primary" />
                    </styleClass>
                </Button>
            </children>
        </HBox>
    </bottom>
</BorderPane>
