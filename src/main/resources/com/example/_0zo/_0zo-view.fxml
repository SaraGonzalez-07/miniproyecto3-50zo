<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>



<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example._0zo.controller._0zoController"
            prefWidth="1100"
            prefHeight="650"
            styleClass="root">

    <!-- TOP BAR -->

    <top>

        <HBox spacing="15"
              alignment="CENTER"
              styleClass="top-panel">

            <Label text="50ZO"
                   styleClass="title"/>

            <Label text="Machines:"
                   styleClass="label"/>

            <ComboBox fx:id="machineSelector"
                      promptText="Select"
                      prefWidth="100"/>

            <Button fx:id="startButton"
                    text="START"
                    styleClass="gold-button"/>

            <Button fx:id="restartButton"
                    text="RESTART"
                    styleClass="gold-button"/>

            <Button fx:id="exitButton"
                    text="EXIT"
                    styleClass="danger-button"/>

        </HBox>

    </top>

    <!-- GAME AREA -->

    <center>

        <GridPane alignment="CENTER"
                  hgap="30"
                  vgap="25"
                  styleClass="game-table">

            <!-- MACHINE 3 -->

            <VBox GridPane.rowIndex="0"
                  GridPane.columnIndex="1"
                  alignment="CENTER"
                  spacing="5"
                  styleClass="player-box">

                <Label fx:id="topPlayerName"
                       text="Machine 3"
                       styleClass="player-name"/>

                <Circle radius="22"
                        styleClass="avatar"/>

                <HBox fx:id="topMachineHand"
                      spacing="5"
                      alignment="CENTER"/>

            </VBox>

            <!-- MACHINE 1 -->

            <VBox GridPane.rowIndex="1"
                  GridPane.columnIndex="0"
                  alignment="CENTER"
                  spacing="5"
                  styleClass="player-box">

                <Label fx:id="leftPlayerName"
                       text="Machine 1"
                       styleClass="player-name"/>

                <Circle radius="22"
                        styleClass="avatar"/>

                <HBox fx:id="leftMachineHand"
                      spacing="5"
                      alignment="CENTER"/>

            </VBox>

            <!-- CENTER TABLE -->

            <VBox GridPane.rowIndex="1"
                  GridPane.columnIndex="1"
                  alignment="CENTER"
                  spacing="15"
                  styleClass="center-zone">

                <Label text="TABLE SUM"
                       styleClass="counter-title"/>

                <Label fx:id="lblTableSum"
                       text="0"
                       styleClass="counter"/>

                <HBox spacing="40"
                      alignment="CENTER">

                    <!-- DECK -->

                    <VBox alignment="CENTER">

                        <Label text="DECK"/>

                        <StackPane fx:id="drawPile"
                                   styleClass="card">

                        </StackPane>

                    </VBox>

                    <!-- TABLE CARD -->

                    <VBox alignment="CENTER">

                        <Label text="TABLE CARD"/>

                        <StackPane styleClass="card">

                            <Label fx:id="currentCard"
                                   text="?"
                                   styleClass="card-number"/>

                        </StackPane>

                    </VBox>

                </HBox>

                <Label text="SCORE"
                       styleClass="counter-title"/>

                <Label fx:id="scoreValue"
                       text="0"
                       styleClass="score"/>

            </VBox>

            <!-- MACHINE 2 -->

            <VBox GridPane.rowIndex="1"
                  GridPane.columnIndex="2"
                  alignment="CENTER"
                  spacing="5"
                  styleClass="player-box">

                <Label fx:id="rightPlayerName"
                       text="Machine 2"
                       styleClass="player-name"/>

                <Circle radius="22"
                        styleClass="avatar"/>

                <HBox fx:id="rightMachineHand"
                      spacing="5"
                      alignment="CENTER"/>

            </VBox>

        </GridPane>

    </center>

    <!-- HUMAN PLAYER -->

    <bottom>

        <VBox alignment="CENTER"
              spacing="10"
              styleClass="bottom-player">

            <Label fx:id="mainPlayerName"
                   text="Human Player"
                   styleClass="player-name"/>

            <HBox fx:id="playerHand"
                  spacing="15"
                  alignment="CENTER"/>

        </VBox>

    </bottom>

</BorderPane>